<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Portfolio — Hastings Holdings Group</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0C0D0F;--surface:#141619;--surface-2:#1A1D22;--hairline:#24272C;
    --text:#E7E9EC;--text-dim:#969CA4;--text-faint:#5F646B;--mint:#4FE3A1;
    --sans:"General Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,"SF Mono",monospace;
    --r:10px;--r-sm:6px;--pad:28px;}
  *{box-sizing:border-box;} html,body{margin:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;
       line-height:1.5;-webkit-font-smoothing:antialiased;}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;}
  .shell{max-width:960px;margin:0 auto;padding:40px var(--pad);}
  .head{display:flex;align-items:center;gap:12px;margin-bottom:32px;}
  .head .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  .head h1{font-size:22px;font-weight:600;margin:0;letter-spacing:.2px;}
  .head span{color:var(--text-faint);font-size:13px;margin-left:auto;}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;}
  .card{display:block;background:var(--surface);border:1px solid var(--hairline);border-radius:var(--r);
        padding:20px;text-decoration:none;color:var(--text);transition:border-color .15s,background .15s;}
  .card:hover{border-color:var(--mint);background:var(--surface-2);}
  .card .name{font-weight:600;font-size:15px;margin-bottom:4px;}
  .card .addr{color:var(--text-faint);font-size:12.5px;}
  .card .stats{display:flex;gap:18px;margin-top:14px;color:var(--text-dim);font-size:12.5px;}
  .card .stats b{font-family:var(--mono);font-weight:500;display:block;font-size:14px;color:var(--text);margin-bottom:1px;}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(79,227,161,.45);}70%{box-shadow:0 0 0 7px rgba(79,227,161,0);}100%{box-shadow:0 0 0 0 rgba(79,227,161,0);}}
  @media(prefers-reduced-motion:reduce){*{animation:none!important;}}
</style>
</head>
<body>
<div class="shell">
  <div class="head">
    <div class="dot" aria-hidden="true"></div>
    <h1>All properties</h1>
    <span><%= allBuildings.length %> buildings</span>
  </div>
  <div class="grid">
<% for (const b of allBuildings) { %>
    <a href="/budget-vs-actual?building=<%= b.id %>" class="card">
      <div class="name"><%= b.name %></div>
      <div class="addr"><%= b.address %>, <%= b.city %></div>
      <div class="stats">
        <div><b class="num"><%= b.rentable_area_sqft.toLocaleString('en-US') %></b> sqft</div>
      </div>
    </a>
<% } %>
  </div>
</div>
</body>
</html>
