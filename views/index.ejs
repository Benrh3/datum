<%
function fmt(cents) { return '$' + (Math.abs(cents) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 }); }
function fmtVar(cents) { if (cents === 0) return '$0'; return (cents > 0 ? '+' : '−') + fmt(cents); }
%>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= dashboard ? dashboard.building.name + ' — Overview' : 'Portfolio — All Properties' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0C0D0F;--surface:#141619;--surface-2:#1A1D22;--hairline:#24272C;
    --text:#E7E9EC;--text-dim:#969CA4;--text-faint:#5F646B;--mint:#4FE3A1;--clay:#DB9A63;
    --sans:"General Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,"SF Mono",monospace;
    --r:10px;--r-sm:6px;--pad:28px;}
  *{box-sizing:border-box;} html,body{margin:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;
       line-height:1.5;-webkit-font-smoothing:antialiased;}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;}

<% if (!dashboard) { %>
  /* ── portfolio grid ─────────────────────────────────────────── */
  .shell{max-width:960px;margin:0 auto;padding:40px var(--pad);}
  .head{display:flex;align-items:center;gap:12px;margin-bottom:32px;}
  .head .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  .head h1{font-size:22px;font-weight:600;margin:0;letter-spacing:.2px;}
  .head span{color:var(--text-faint);font-size:13px;margin-left:auto;}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;}
  .card{display:block;background:var(--surface);border:1px solid var(--hairline);border-radius:var(--r);
        padding:20px;text-decoration:none;color:var(--text);transition:border-color .15s,background .15s;}
  .card:hover{border-color:var(--mint);background:var(--surface-2);}
  .card .name{font-weight:600;font-size:15px;margin-bottom:4px;}
  .card .addr{color:var(--text-faint);font-size:12.5px;}
  .card .stats{display:flex;gap:18px;margin-top:14px;color:var(--text-dim);font-size:12.5px;}
  .card .stats b{font-family:var(--mono);font-weight:500;display:block;font-size:14px;color:var(--text);margin-bottom:1px;}
<% } else { %>
  /* ── building dashboard ─────────────────────────────────────── */
  .app{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
  .rail{border-right:1px solid var(--hairline);padding:22px 16px;display:flex;flex-direction:column;gap:26px;}
  .brand{display:flex;align-items:center;gap:10px;padding:4px 8px;}
  .brand .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  nav{display:flex;flex-direction:column;gap:2px;}
  nav a{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:var(--r-sm);color:var(--text-dim);text-decoration:none;font-weight:500;border-left:2px solid transparent;}
  nav a:hover{background:var(--surface);color:var(--text);}
  nav a.active{color:var(--text);background:var(--surface);border-left-color:var(--mint);}
  nav a svg{width:16px;height:16px;stroke-width:1.6;opacity:.9;}
  .nav-label{font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--text-faint);padding:0 12px;margin-bottom:4px;}
  .bldg-pick{width:100%;background:transparent;border:1px solid transparent;border-radius:var(--r-sm);color:var(--text);font-family:var(--sans);font-weight:600;font-size:14px;letter-spacing:.2px;padding:4px 22px 4px 0;appearance:none;cursor:pointer;outline:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%235F646B' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 2px center;}
  .bldg-pick:hover,.bldg-pick:focus{border-color:var(--hairline);}
  .bldg-pick option{background:var(--surface);color:var(--text);}
  .hamburger{display:none;width:44px;height:44px;background:none;border:none;cursor:pointer;padding:10px;color:var(--text-dim);-webkit-tap-highlight-color:transparent;}
  .hamburger svg{width:24px;height:24px;stroke-width:1.8;}

  .main{min-width:0;}
  .topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px var(--pad);border-bottom:1px solid var(--hairline);}
  .crumb{color:var(--text-faint);font-size:12.5px;} .crumb b{color:var(--text-dim);font-weight:500;}
  .topbar h1{font-size:19px;font-weight:600;margin:2px 0 0;letter-spacing:.2px;}
  .live{display:flex;align-items:center;gap:7px;color:var(--text-dim);font-size:12.5px;}
  .live .d{width:7px;height:7px;border-radius:50%;background:var(--mint);box-shadow:0 0 0 0 rgba(79,227,161,.5);animation:pulse 2.6s ease-out infinite;}

  .kpis{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;padding:24px var(--pad);border-bottom:1px solid var(--hairline);}
  .kpi{background:var(--surface);border:1px solid var(--hairline);border-radius:var(--r);padding:18px 20px;}
  .kpi .lbl{color:var(--text-faint);font-size:11px;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;}
  .kpi .fig{font-family:var(--mono);font-variant-numeric:tabular-nums;font-size:28px;font-weight:500;letter-spacing:-.5px;}
  .kpi .sub{color:var(--text-dim);font-size:12.5px;margin-top:4px;}
  .kpi .bar{width:100%;height:4px;border-radius:2px;background:var(--surface-2);margin-top:10px;}
  .kpi .bar i{display:block;height:100%;border-radius:2px;}

  .attn{padding:24px var(--pad) 40px;}
  .attn h2{font-size:14px;font-weight:600;margin:0 0 14px;letter-spacing:.2px;}
  .attn-list{border:1px solid var(--hairline);border-radius:var(--r);background:var(--surface);overflow:hidden;}
  .attn-item{display:flex;align-items:center;gap:12px;padding:13px 16px;border-bottom:1px solid var(--hairline);text-decoration:none;color:var(--text);transition:background .12s;}
  .attn-item:last-child{border-bottom:none;}
  .attn-item:hover{background:var(--surface-2);}
  .attn-item .ic{width:6px;height:6px;border-radius:50%;flex:none;}
  .attn-item .lbl{flex:1;font-weight:500;font-size:13px;}
  .attn-item .val{font-family:var(--mono);font-size:13px;color:var(--text-dim);}
<% } %>

  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(79,227,161,.45);}70%{box-shadow:0 0 0 7px rgba(79,227,161,0);}100%{box-shadow:0 0 0 0 rgba(79,227,161,0);}}
  @media(prefers-reduced-motion:reduce){*{animation:none!important;}}
  :focus-visible{outline:2px solid var(--mint);outline-offset:2px;border-radius:4px;}
</style>
</head>
<body>

<% if (!dashboard) { %>
<!-- ═══ Portfolio grid (no building selected) ═══ -->
<div class="shell">
  <div class="head">
    <div class="dot" aria-hidden="true"></div>
    <h1>All properties</h1>
    <span><%= allBuildings.length %> buildings</span>
  </div>
  <div class="grid">
<% for (const b of allBuildings) { %>
    <a href="/?building=<%= b.id %>" class="card">
      <div class="name"><%= b.name %></div>
      <div class="addr"><%= b.address %>, <%= b.city %></div>
      <div class="stats">
        <div><b class="num"><%= b.rentable_area_sqft.toLocaleString('en-US') %></b> sqft</div>
      </div>
    </a>
<% } %>
  </div>
</div>

<% } else { %>
<%
  const d = dashboard;
  const varFav = d.variance <= 0;
%>
<!-- ═══ Per-building dashboard ═══ -->
<div class="app">
  <aside class="rail">
    <div class="brand"><div class="dot" aria-hidden="true"></div><div>
      <select class="bldg-pick" id="bldg-pick">
<% for (const b of allBuildings) { %>
        <option value="<%= b.id %>"<%= b.id === d.buildingId ? ' selected' : '' %>><%= b.name %></option>
<% } %>
      </select>
    </div></div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/?building=<%= d.buildingId %>" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll?building=<%= d.buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual?building=<%= d.buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="/ap-review?building=<%= d.buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <a href="/receivables?building=<%= d.buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v20M2 12h20M6 6l12 12M18 6L6 18"/></svg><span class="t">Receivables</span></a>
      <a href="/maintenance?building=<%= d.buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg><span class="t">Maintenance</span></a>
      <div class="nav-label">Reports</div>
      <a href="/reports/owner-statement"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="t">Owner statement</span></a>
      <a href="/reports/miscoding-review"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 9v4m0 4h.01M10.3 3.9L2 18a2 2 0 001.7 3h16.6a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg><span class="t">Miscoding review</span></a>
    </nav>
  </aside>

  <main class="main">
    <div class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
      <div>
        <div class="crumb"><b>Portfolio</b> &nbsp;/&nbsp; Overview</div>
        <h1><%= d.building.name %></h1>
      </div>
      <span class="live"><span class="d" aria-hidden="true"></span> As of <span id="asof"></span></span>
    </div>

    <!-- KPI cards -->
    <div class="kpis">
      <div class="kpi">
        <div class="lbl">Occupancy</div>
        <div class="fig" style="color:var(<%= d.occupancyPct >= 80 ? '--mint' : '--clay' %>)"><%= d.occupancyPct.toFixed(0) %>%</div>
        <div class="sub"><%= d.occupiedSuites %> of <%= d.totalSuites %> suites &middot; <%= d.occupiedArea.toLocaleString('en-US') %> sqft</div>
        <div class="bar"><i style="width:<%= Math.min(100, d.occupancyPct) %>%;background:var(<%= d.occupancyPct >= 80 ? '--mint' : '--clay' %>)"></i></div>
      </div>

      <div class="kpi">
        <div class="lbl">Budget variance</div>
        <div class="fig" style="color:var(<%= varFav ? '--mint' : '--clay' %>)"><%= fmtVar(d.variance) %></div>
        <div class="sub">Budget <%= fmt(d.budget) %> &middot; Actual <%= fmt(d.actual) %></div>
      </div>

      <div class="kpi">
        <div class="lbl">AR arrears</div>
        <div class="fig" style="color:var(<%= d.totalArrears > 0 ? '--clay' : '--mint' %>)"><%= fmt(d.totalArrears) %></div>
        <div class="sub"><%= d.tenantsInArrears %> tenant<%= d.tenantsInArrears !== 1 ? 's' : '' %> outstanding</div>
      </div>

      <div class="kpi">
        <div class="lbl">Open maintenance</div>
        <div class="fig"><%= d.openMaint %></div>
        <div class="sub"><% if (d.urgentMaint > 0) { %><span style="color:var(--clay)"><%= d.urgentMaint %> urgent</span><% } else { %>No urgent<% } %></div>
      </div>

      <div class="kpi">
        <div class="lbl">Expiring insurance</div>
        <div class="fig" style="color:var(<%= d.expiringCois > 0 ? '--clay' : '--mint' %>)"><%= d.expiringCois %></div>
        <div class="sub">COIs expiring within 60 days</div>
      </div>
    </div>

    <!-- Needs attention -->
    <div class="attn">
      <h2>Needs attention</h2>
<% if (d.attention.length > 0) { %>
      <div class="attn-list">
<% for (const a of d.attention) { %>
        <a href="<%= a.link %>" class="attn-item">
          <span class="ic" style="background:var(<%= a.type === 'budget' || a.type === 'arrears' || a.type === 'insurance' || a.type === 'maintenance' ? '--clay' : '--mint' %>)"></span>
          <span class="lbl"><%= a.label %></span>
          <span class="val"><%= a.detail %></span>
        </a>
<% } %>
      </div>
<% } else { %>
      <%- include('partials/empty-state', { message: 'Nothing flagged for ' + d.building.name + '.', sub: 'All accounts within budget, no arrears, insurance current, no urgent maintenance.' }) %>
<% } %>
    </div>
  </main>
</div>

<div class="nav-backdrop" id="nav-backdrop"></div>
<link rel="stylesheet" href="/mobile.css">
<script>
(function(){
  var pick = document.getElementById('bldg-pick');
  if (pick) pick.addEventListener('change', function(){ window.location.href = '/?building=' + this.value; });
  try { document.getElementById('asof').textContent = new Date().toLocaleDateString('en-CA',{month:'short',day:'numeric',year:'numeric'}); } catch(e){}
  var rail=document.querySelector('.rail'),bd=document.getElementById('nav-backdrop'),btn=document.getElementById('hamburger');
  if(rail&&bd&&btn){
    function open(){rail.classList.add('open');bd.classList.add('open');}
    function close(){rail.classList.remove('open');bd.classList.remove('open');}
    btn.addEventListener('click',function(e){e.stopPropagation();rail.classList.contains('open')?close():open();});
    bd.addEventListener('click',close);
    rail.addEventListener('click',function(e){if(e.target.closest('a'))close();});
  }
})();
</script>
<% } %>
</body>
</html>
