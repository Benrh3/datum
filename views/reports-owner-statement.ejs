<%
function fmt(cents) {
  return '$' + (Math.abs(cents) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 });
}
function fmtVar(cents) {
  if (cents === 0) return '$0';
  return (cents > 0 ? '+' : '−') + fmt(cents);
}
function pctVar(budget, actual) {
  if (budget === 0) return 0;
  return (actual - budget) / Math.abs(budget) * 100;
}
function fmtPct(p) {
  if (Math.abs(p) < 0.05) return '0.0%';
  return (p > 0 ? '+' : '−') + Math.abs(p).toFixed(1) + '%';
}
function cls(v) { return v > 0 ? 'unf' : v < 0 ? 'fav' : 'flat'; }
function clr(v) { return v > 0 ? '--clay' : v < 0 ? '--mint' : '--text-faint'; }
const totalVariance = totalActual - totalBudget;
const varPct = totalBudget ? pctVar(totalBudget, totalActual) : 0;
%>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Owner statement<%= entity ? ' — ' + entity.name : '' %></title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --bg:#0C0D0F;--surface:#141619;--surface-2:#1A1D22;--hairline:#24272C;
    --text:#E7E9EC;--text-dim:#969CA4;--text-faint:#5F646B;
    --mint:#4FE3A1;--clay:#DB9A63;
    --sans:"General Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,"SF Mono",monospace;
    --r:10px;--r-sm:6px;--pad:28px;
  }
  *{box-sizing:border-box;} html,body{margin:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;
       line-height:1.5;-webkit-font-smoothing:antialiased;letter-spacing:.1px;}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;}

  .app{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
  .rail{border-right:1px solid var(--hairline);padding:22px 16px;display:flex;flex-direction:column;gap:26px;}
  .brand{display:flex;align-items:center;gap:10px;padding:4px 8px;}
  .brand .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  .brand b{font-weight:600;letter-spacing:.2px;}
  nav{display:flex;flex-direction:column;gap:2px;}
  nav a{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:var(--r-sm);
        color:var(--text-dim);text-decoration:none;font-weight:500;border-left:2px solid transparent;}
  nav a:hover{background:var(--surface);color:var(--text);}
  nav a.active{color:var(--text);background:var(--surface);border-left-color:var(--mint);}
  nav a svg{width:16px;height:16px;stroke-width:1.6;opacity:.9;}
  .nav-label{font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--text-faint);padding:0 12px;margin-bottom:4px;}

  .main{min-width:0;}
  .topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;
          padding:18px var(--pad);border-bottom:1px solid var(--hairline);}
  .crumb{color:var(--text-faint);font-size:12.5px;} .crumb b{color:var(--text-dim);font-weight:500;}
  .topbar h1{font-size:19px;font-weight:600;margin:2px 0 0;letter-spacing:.2px;}

  .ctl{height:31px;background:var(--surface);border:1px solid var(--hairline);border-radius:var(--r-sm);
       color:var(--text-dim);padding:0 28px 0 10px;font-family:var(--sans);font-size:12.5px;font-weight:500;
       outline:none;-webkit-appearance:none;-moz-appearance:none;appearance:none;cursor:pointer;
       background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23969CA4' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
       background-repeat:no-repeat;background-position:right 10px center;transition:border-color .15s;}
  .ctl:hover{color:var(--text);} .ctl:focus{border-color:var(--mint);color:var(--text);}
  .ctl option{background:var(--surface);color:var(--text);}

  .summary{display:flex;gap:30px;padding:24px var(--pad);border-bottom:1px solid var(--hairline);}
  .summary div span{display:block;color:var(--text-faint);font-size:12px;margin-bottom:3px;}
  .summary div b{font-family:var(--mono);font-weight:500;font-size:16px;}

  .report{padding:22px var(--pad) 40px;}
  .report-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;}
  .report-head h2{font-size:14px;font-weight:600;margin:0;letter-spacing:.2px;}
  .report-head .hint{color:var(--text-faint);font-size:12px;}
  .controls{display:flex;gap:8px;align-items:center;}

  .tbl-wrap{overflow-x:auto;border:1px solid var(--hairline);border-radius:var(--r);background:var(--surface);}
  table{width:100%;border-collapse:collapse;min-width:640px;}
  thead th{text-align:right;font-weight:500;color:var(--text-faint);font-size:11px;letter-spacing:.8px;
           text-transform:uppercase;padding:13px 16px;border-bottom:1px solid var(--hairline);white-space:nowrap;}
  thead th.l{text-align:left;}
  tbody td{padding:14px 16px;border-bottom:1px solid var(--hairline);text-align:right;white-space:nowrap;}
  tbody tr:last-child td{border-bottom:none;}
  tbody tr:hover{background:var(--surface-2);}
  td.l{text-align:left;}
  .chip{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:12.5px;padding:3px 8px;border-radius:var(--r-sm);}
  .chip.fav{color:var(--mint);background:rgba(79,227,161,.10);}
  .chip.unf{color:var(--clay);background:rgba(219,154,99,.10);}
  .chip.flat{color:var(--text-faint);background:var(--surface-2);}
  .pct-badge{font-family:var(--mono);font-size:12px;color:var(--text-faint);margin-left:4px;}

  tfoot td{padding:15px 16px;border-top:1px solid var(--hairline);font-weight:600;text-align:right;}
  tfoot td.l{text-align:left;}

  .bldg-pick{width:100%;background:transparent;border:1px solid transparent;border-radius:var(--r-sm);
    color:var(--text);font-family:var(--sans);font-weight:600;font-size:14px;letter-spacing:.2px;
    padding:4px 22px 4px 0;appearance:none;cursor:pointer;outline:none;
    background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%235F646B' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat:no-repeat;background-position:right 2px center;}
  .bldg-pick:hover,.bldg-pick:focus{border-color:var(--hairline);}
  .bldg-pick option{background:var(--surface);color:var(--text);}

  .empty{text-align:center;color:var(--text-faint);padding:60px var(--pad);}

  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(79,227,161,.45);}70%{box-shadow:0 0 0 7px rgba(79,227,161,0);}100%{box-shadow:0 0 0 0 rgba(79,227,161,0);}}
  @media(prefers-reduced-motion:reduce){*{animation:none!important;}}
  :focus-visible{outline:2px solid var(--mint);outline-offset:2px;border-radius:4px;}

</style>
</head>
<body>
<div class="app">
  <aside class="rail">
    <div class="brand">
      <div class="dot" aria-hidden="true"></div>
      <div>
        <select class="bldg-pick" id="bldg-pick">
<% for (const b of allBuildings) { %>
          <option value="<%= b.id %>"><%= b.name %></option>
<% } %>
        </select>
      </div>
    </div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="/ap-review"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <div class="nav-label">Reports</div>
      <a href="/reports/owner-statement" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="t">Owner statement</span></a>
    </nav>
  </aside>

  <main class="main">
    <div class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
      <div>
        <div class="crumb"><b>Reports</b> &nbsp;/&nbsp; Owner statement</div>
        <h1>Owner statement</h1>
      </div>
      <div class="controls">
        <select class="ctl" id="entity-pick">
          <option value="">Select company…</option>
<% for (const e of entities) { %>
          <option value="<%= e.id %>"<%= entity && entity.id === e.id ? ' selected' : '' %>><%= e.name %></option>
<% } %>
        </select>
      </div>
    </div>

<% if (entity && rows.length > 0) { %>
    <section class="summary">
      <div><span>Company</span><b><%= entity.name %></b></div>
      <div><span>Properties</span><b><%= rows.length %></b></div>
      <div><span>Budgeted (apportioned)</span><b><%= fmt(totalBudget) %></b></div>
      <div><span>Actual (apportioned)</span><b><%= fmt(totalActual) %></b></div>
      <div><span>Variance</span><b style="color:var(<%= clr(totalVariance) %>)"><%= fmtVar(totalVariance) %></b></div>
    </section>

    <section class="report">
      <div class="report-head">
        <div>
          <h2>By property</h2>
          <span class="hint">Q<%= Math.ceil(period / 3) %> <%= year %> &middot; amounts apportioned by ownership %</span>
        </div>
      </div>

      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th class="l">Property</th>
              <th>Ownership</th>
              <th>Budget</th>
              <th>Actual</th>
              <th>Variance</th>
              <th>%</th>
            </tr>
          </thead>
          <tbody>
<% for (const r of rows) { const vp = r.budget_cents ? pctVar(r.budget_cents, r.actual_cents) : 0; %>
            <tr>
              <td class="l" style="font-weight:500"><%= r.building_name %></td>
              <td class="num"><%= r.ownership_pct %>%</td>
              <td class="num"><%= fmt(r.budget_cents) %></td>
              <td class="num"><%= fmt(r.actual_cents) %></td>
              <td><span class="chip <%= cls(r.variance_cents) %>"><%= fmtVar(r.variance_cents) %></span></td>
              <td class="num" style="color:var(<%= clr(r.variance_cents) %>)"><%= fmtPct(vp) %></td>
            </tr>
<% } %>
          </tbody>
          <tfoot>
            <tr>
              <td class="l">Total (<%= entity.name %>)</td>
              <td></td>
              <td class="num"><%= fmt(totalBudget) %></td>
              <td class="num"><%= fmt(totalActual) %></td>
              <td><span class="chip <%= cls(totalVariance) %>"><%= fmtVar(totalVariance) %></span></td>
              <td class="num" style="color:var(<%= clr(totalVariance) %>)"><%= fmtPct(varPct) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </section>
<% } else if (entity) { %>
    <div style="padding:var(--pad)"><%- include('partials/empty-state', { message: 'No financial data for ' + entity.name + ' in this period.', sub: 'Budget rows for this entity\'s buildings have not been entered yet.' }) %></div>
<% } else { %>
    <div style="padding:var(--pad)"><%- include('partials/empty-state', { message: 'Select a company above to generate the owner statement.' }) %></div>
<% } %>
  </main>
</div>

<script>
(function () {
  document.getElementById('entity-pick').addEventListener('change', function () {
    if (this.value) window.location.href = '/reports/owner-statement?entity=' + this.value;
  });
  document.getElementById('bldg-pick').addEventListener('change', function () {
    window.location.href = '/budget-vs-actual?building=' + this.value;
  });
})();
</script>
<%- include('partials/mobile-nav') %>
</body>
</html>
