<%
function fmt(cents) { return '$' + (Math.abs(cents) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 }); }
%>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Miscoding review</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0C0D0F;--surface:#141619;--surface-2:#1A1D22;--hairline:#24272C;
    --text:#E7E9EC;--text-dim:#969CA4;--text-faint:#5F646B;--mint:#4FE3A1;--clay:#DB9A63;
    --sans:"General Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,"SF Mono",monospace;
    --r:10px;--r-sm:6px;--pad:28px;}
  *{box-sizing:border-box;} html,body{margin:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased;}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;}
  .app{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
  .rail{border-right:1px solid var(--hairline);padding:22px 16px;display:flex;flex-direction:column;gap:26px;}
  .brand{display:flex;align-items:center;gap:10px;padding:4px 8px;}
  .brand .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  nav{display:flex;flex-direction:column;gap:2px;}
  nav a{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:var(--r-sm);color:var(--text-dim);text-decoration:none;font-weight:500;border-left:2px solid transparent;}
  nav a:hover{background:var(--surface);color:var(--text);}
  nav a.active{color:var(--text);background:var(--surface);border-left-color:var(--mint);}
  nav a svg{width:16px;height:16px;stroke-width:1.6;opacity:.9;}
  .nav-label{font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--text-faint);padding:0 12px;margin-bottom:4px;}
  .bldg-pick{width:100%;background:transparent;border:1px solid transparent;border-radius:var(--r-sm);color:var(--text);font-family:var(--sans);font-weight:600;font-size:14px;letter-spacing:.2px;padding:4px 22px 4px 0;appearance:none;cursor:pointer;outline:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%235F646B' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 2px center;}
  .bldg-pick:hover,.bldg-pick:focus{border-color:var(--hairline);}
  .bldg-pick option{background:var(--surface);color:var(--text);}
  .main{min-width:0;}
  .topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px var(--pad);border-bottom:1px solid var(--hairline);}
  .crumb{color:var(--text-faint);font-size:12.5px;} .crumb b{color:var(--text-dim);font-weight:500;}
  .topbar h1{font-size:19px;font-weight:600;margin:2px 0 0;letter-spacing:.2px;}
  .report{padding:22px var(--pad) 40px;}
  .report h2{font-size:14px;font-weight:600;margin:0 0 4px;letter-spacing:.2px;}
  .report .hint{color:var(--text-faint);font-size:12px;margin-bottom:14px;display:block;}
  .tbl-wrap{overflow-x:auto;border:1px solid var(--hairline);border-radius:var(--r);background:var(--surface);margin-bottom:28px;}
  table{width:100%;border-collapse:collapse;min-width:640px;}
  thead th{text-align:right;font-weight:500;color:var(--text-faint);font-size:11px;letter-spacing:.8px;text-transform:uppercase;padding:13px 16px;border-bottom:1px solid var(--hairline);white-space:nowrap;}
  thead th.l{text-align:left;}
  tbody td{padding:14px 16px;border-bottom:1px solid var(--hairline);text-align:right;white-space:nowrap;}
  tbody tr:last-child td{border-bottom:none;}
  tbody tr:hover{background:var(--surface-2);}
  td.l{text-align:left;}
  .code{font-family:var(--mono);font-size:12.5px;color:var(--text-dim);}
  .empty{color:var(--text-faint);padding:40px;text-align:center;}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(79,227,161,.45);}70%{box-shadow:0 0 0 7px rgba(79,227,161,0);}100%{box-shadow:0 0 0 0 rgba(79,227,161,0);}}
  @media(prefers-reduced-motion:reduce){*{animation:none!important;}}
  :focus-visible{outline:2px solid var(--mint);outline-offset:2px;border-radius:4px;}

</style>
</head>
<body>
<div class="app">
  <aside class="rail">
    <div class="brand"><div class="dot" aria-hidden="true"></div><div>
      <select class="bldg-pick" id="bldg-pick"><% for (const b of allBuildings) { %><option value="<%= b.id %>"><%= b.name %></option><% } %></select>
    </div></div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="/ap-review"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <div class="nav-label">Reports</div>
      <a href="/reports/owner-statement"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="t">Owner statement</span></a>
      <a href="/reports/miscoding-review" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 9v4m0 4h.01M10.3 3.9L2 18a2 2 0 001.7 3h16.6a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg><span class="t">Miscoding review</span></a>
    </nav>
  </aside>

  <main class="main">
    <div class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
      <div>
        <div class="crumb"><b>Reports</b> &nbsp;/&nbsp; Miscoding review</div>
        <h1>Miscoding review</h1>
      </div>
    </div>

    <section class="report">
      <h2>Unusual coding</h2>
      <span class="hint">Lines coded to an account that differs from the vendor's default &middot; Q<%= Math.ceil(period / 3) %> <%= year %></span>
<% if (unusualRows.length > 0) { %>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th class="l">Vendor</th><th class="l">Invoice</th><th class="l">Description</th><th>Coded</th><th>Vendor default</th><th>Amount</th></tr></thead>
          <tbody>
<% for (const r of unusualRows) { %>
            <tr>
              <td class="l" style="font-weight:500"><%= r.vendor_name %></td>
              <td class="l"><a href="/ap-review?invoice=<%= r.invoice_id %>" style="color:var(--mint);text-decoration:none"><%= r.invoice_number || '#' + r.invoice_id %></a></td>
              <td class="l" style="max-width:200px;overflow:hidden;text-overflow:ellipsis"><%= r.description %></td>
              <td class="code" style="color:var(--clay)"><%= r.line_code %></td>
              <td class="code"><%= r.default_code %></td>
              <td class="num"><%= fmt(r.amount_cents) %></td>
            </tr>
<% } %>
          </tbody>
        </table>
      </div>
<% } else { %>
      <%- include('partials/empty-state', { message: 'No unusual coding found for this period.', sub: 'All lines match their vendor\'s default GL code.' }) %>
<% } %>

      <h2>Over-budget lines</h2>
      <span class="hint">Lines on accounts that are &gt;10% over budget &middot; Q<%= Math.ceil(period / 3) %> <%= year %></span>
<% if (overBudgetRows.length > 0) { %>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th class="l">Vendor</th><th class="l">Invoice</th><th class="l">Description</th><th>Account</th><th>Budget</th><th>Actual</th><th>Amount</th></tr></thead>
          <tbody>
<% for (const r of overBudgetRows) { %>
            <tr>
              <td class="l" style="font-weight:500"><%= r.vendor_name %></td>
              <td class="l"><a href="/ap-review?invoice=<%= r.invoice_id %>" style="color:var(--mint);text-decoration:none"><%= r.invoice_number || '#' + r.invoice_id %></a></td>
              <td class="l" style="max-width:200px;overflow:hidden;text-overflow:ellipsis"><%= r.description %></td>
              <td class="code" style="color:var(--clay)"><%= r.line_code %></td>
              <td class="num"><%= fmt(r.budget_cents) %></td>
              <td class="num"><%= fmt(r.actual_cents) %></td>
              <td class="num"><%= fmt(r.amount_cents) %></td>
            </tr>
<% } %>
          </tbody>
        </table>
      </div>
<% } else { %>
      <%- include('partials/empty-state', { message: 'No accounts materially over budget for this period.', sub: 'No account exceeds its budget by more than 10%.' }) %>
<% } %>
    </section>
  </main>
</div>
<script>
document.getElementById('bldg-pick').addEventListener('change', function () {
  window.location.href = '/budget-vs-actual?building=' + this.value;
});
</script>
<%- include('partials/mobile-nav') %>
</body>
</html>
