<%
function fmtDate(iso) {
  if (!iso) return '—';
  var p = iso.split('T')[0].split('-');
  var m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return m[+p[1] - 1] + ' ' + +p[2] + ', ' + p[0];
}
function truncate(s, n) { return s && s.length > n ? s.slice(0, n) + '...' : (s || '—'); }

var tab = typeof locals.tab !== 'undefined' ? locals.tab : 'requests';
var openCount = requests.filter(function(r) { return r.status !== 'completed' && r.status !== 'closed'; }).length;
var urgentCount = requests.filter(function(r) { return r.priority === 'emergency' || r.priority === 'urgent'; }).length;
%>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Maintenance — <%= building.name %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0C0D0F;--surface:#141619;--surface-2:#1A1D22;--hairline:#24272C;
    --text:#E7E9EC;--text-dim:#969CA4;--text-faint:#5F646B;--mint:#4FE3A1;--clay:#DB9A63;
    --sans:"General Sans",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,"SF Mono",monospace;
    --r:10px;--r-sm:6px;--pad:28px;}
  *{box-sizing:border-box;}html,body{margin:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;
       line-height:1.5;-webkit-font-smoothing:antialiased;letter-spacing:.1px;}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;}

  .app{display:grid;grid-template-columns:232px 1fr;min-height:100vh;}
  .rail{border-right:1px solid var(--hairline);padding:22px 16px;display:flex;flex-direction:column;gap:26px;}
  .brand{display:flex;align-items:center;gap:10px;padding:4px 8px;}
  .brand .dot{width:9px;height:9px;border-radius:50%;background:var(--mint);animation:pulse 2.6s ease-out infinite;}
  nav{display:flex;flex-direction:column;gap:2px;}
  nav a{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:var(--r-sm);
        color:var(--text-dim);text-decoration:none;font-weight:500;border-left:2px solid transparent;}
  nav a:hover{background:var(--surface);color:var(--text);}
  nav a.active{color:var(--text);background:var(--surface);border-left-color:var(--mint);}
  nav a svg{width:16px;height:16px;stroke-width:1.6;opacity:.9;}
  .nav-label{font-size:11px;letter-spacing:1.4px;text-transform:uppercase;color:var(--text-faint);padding:0 12px;margin-bottom:4px;}
  .bldg-pick{width:100%;background:transparent;border:1px solid transparent;border-radius:var(--r-sm);
    color:var(--text);font-family:var(--sans);font-weight:600;font-size:14px;letter-spacing:.2px;
    padding:4px 22px 4px 0;appearance:none;cursor:pointer;outline:none;
    background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%235F646B' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat:no-repeat;background-position:right 2px center;}
  .bldg-pick:hover,.bldg-pick:focus{border-color:var(--hairline);}
  .bldg-pick option{background:var(--surface);color:var(--text);}

  .main{min-width:0;}
  .topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;
          padding:18px var(--pad);border-bottom:1px solid var(--hairline);}
  .crumb{color:var(--text-faint);font-size:12.5px;}.crumb b{color:var(--text-dim);font-weight:500;}
  .topbar h1{font-size:19px;font-weight:600;margin:2px 0 0;letter-spacing:.2px;}

  .summary{display:flex;gap:30px;padding:24px var(--pad);border-bottom:1px solid var(--hairline);}
  .summary div span{display:block;color:var(--text-faint);font-size:12px;margin-bottom:3px;}
  .summary div b{font-family:var(--mono);font-weight:500;font-size:16px;}

  .tabs{display:flex;gap:0;border-bottom:1px solid var(--hairline);padding:0 var(--pad);}
  .tab{padding:12px 18px;font-size:13px;font-weight:500;color:var(--text-dim);text-decoration:none;
       border-bottom:2px solid transparent;margin-bottom:-1px;}
  .tab:hover{color:var(--text);}
  .tab.active{color:var(--text);border-bottom-color:var(--mint);}
  .tab .badge{font-family:var(--mono);font-size:11px;background:var(--surface-2);padding:2px 6px;
              border-radius:var(--r-sm);margin-left:6px;}
  .tab .badge.warn{background:rgba(219,154,99,.10);color:var(--clay);}

  .report{padding:22px var(--pad) 40px;}
  .tbl-wrap{overflow-x:auto;border:1px solid var(--hairline);border-radius:var(--r);background:var(--surface);}
  table{width:100%;border-collapse:collapse;min-width:640px;}
  thead th{text-align:right;font-weight:500;color:var(--text-faint);font-size:11px;letter-spacing:.8px;
           text-transform:uppercase;padding:13px 16px;border-bottom:1px solid var(--hairline);white-space:nowrap;}
  thead th.l{text-align:left;}
  tbody td{padding:14px 16px;border-bottom:1px solid var(--hairline);text-align:right;white-space:nowrap;}
  tbody tr:last-child td{border-bottom:none;}
  tbody tr:hover{background:var(--surface-2);}
  td.l{text-align:left;}

  .chip{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:500;
        padding:3px 8px;border-radius:var(--r-sm);letter-spacing:.2px;}
  .chip.ok{color:var(--mint);background:rgba(79,227,161,.10);}
  .chip.block{color:var(--clay);background:rgba(219,154,99,.10);}
  .chip.pend{color:var(--text-dim);background:var(--surface-2);}

  .cat-badge{display:inline-block;font-size:11px;letter-spacing:.5px;text-transform:uppercase;
             color:var(--text-faint);font-weight:500;}

  .desc-cell{max-width:260px;overflow:hidden;text-overflow:ellipsis;color:var(--text-dim);}

  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(79,227,161,.45);}70%{box-shadow:0 0 0 7px rgba(79,227,161,0);}100%{box-shadow:0 0 0 0 rgba(79,227,161,0);}}
  @media(prefers-reduced-motion:reduce){*{animation:none!important;}}
  :focus-visible{outline:2px solid var(--mint);outline-offset:2px;border-radius:4px;}


</style>
</head>
<body>
<div class="app">
  <aside class="rail">
    <div class="brand"><div class="dot" aria-hidden="true"></div><div>
      <select class="bldg-pick" id="bldg-pick"><% for (const b of allBuildings) { %><option value="<%= b.id %>"<%= b.id === buildingId ? ' selected' : '' %>><%= b.name %></option><% } %></select>
    </div></div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <div class="nav-label">Operations</div>
      <a href="/maintenance?building=<%= buildingId %>" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg><span class="t">Maintenance</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="/ap-review?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <a href="/receivables?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v20M2 12h20M6 6l12 12M18 6L6 18"/></svg><span class="t">Receivables</span></a>
      <div class="nav-label">Reports</div>
      <a href="/reports/owner-statement"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="t">Owner statement</span></a>
      <a href="/reports/miscoding-review"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 9v4m0 4h.01M10.3 3.9L2 18a2 2 0 001.7 3h16.6a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg><span class="t">Miscoding review</span></a>
    </nav>
  </aside>

  <main class="main">
    <div class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
      <div>
        <div class="crumb"><b>Operations</b> &nbsp;/&nbsp; Maintenance</div>
        <h1>Maintenance</h1>
      </div>
    </div>

    <section class="summary">
      <div><span>Total requests</span><b><%= requests.length %></b></div>
      <div><span>Open</span><b style="color:<%= openCount > 0 ? 'var(--clay)' : 'var(--text)' %>"><%= openCount %></b></div>
      <div><span>Urgent</span><b style="color:<%= urgentCount > 0 ? 'var(--clay)' : 'var(--text)' %>"><%= urgentCount %></b></div>
      <div><span>Work orders</span><b><%= workOrders.length %></b></div>
    </section>

    <div class="tabs">
      <a href="?building=<%= buildingId %>&tab=requests" class="tab<%= tab==='requests'?' active':'' %>">Requests<% if (openCount) { %><span class="badge warn"><%= openCount %></span><% } %></a>
      <a href="?building=<%= buildingId %>&tab=work-orders" class="tab<%= tab==='work-orders'?' active':'' %>">Work orders</a>
    </div>

    <section class="report">
<% if (tab === 'requests') { %>
  <% if (requests.length === 0) { %>
      <%- include('partials/empty-state', { message: 'No maintenance requests for ' + building.name + '.', sub: 'Tenant-submitted requests will appear here.' }) %>
  <% } else { %>
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th class="l">Date</th>
              <th class="l">Tenant</th>
              <th class="l">Suite</th>
              <th class="l">Category</th>
              <th class="l">Description</th>
              <th>Priority</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
    <% for (const r of requests) { %>
            <tr>
              <td class="l num"><%= fmtDate(r.submitted_at) %></td>
              <td class="l" style="font-weight:500"><%= r.tenant_name || '—' %></td>
              <td class="l"><%= r.suite_number || '—' %></td>
              <td class="l"><span class="cat-badge"><%= r.category || '—' %></span></td>
              <td class="l desc-cell"><%= truncate(r.description, 60) %></td>
              <td><span class="chip <%= r.priority === 'emergency' || r.priority === 'urgent' ? 'block' : r.priority === 'low' ? 'ok' : 'pend' %>"><%= r.priority %></span></td>
              <td><span class="chip <%= r.status === 'completed' || r.status === 'closed' ? 'ok' : r.status === 'submitted' ? 'pend' : 'block' %>"><%= r.status %></span></td>
            </tr>
    <% } %>
          </tbody>
        </table>
      </div>
  <% } %>

<% } else if (tab === 'work-orders') { %>
  <% if (workOrders.length === 0) { %>
      <%- include('partials/empty-state', { message: 'No work orders for ' + building.name + '.', sub: 'Work orders are created when maintenance requests are assigned to a vendor.' }) %>
  <% } else { %>
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th class="l">ID</th>
              <th class="l">Description</th>
              <th class="l">Tenant</th>
              <th class="l">Suite</th>
              <th class="l">Vendor</th>
              <th>Priority</th>
              <th>Status</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
    <% for (const wo of workOrders) { %>
            <tr>
              <td class="l num"><%= wo.id %></td>
              <td class="l desc-cell"><%= truncate(wo.description || wo.request_desc, 50) %></td>
              <td class="l" style="font-weight:500"><%= wo.tenant_name || '—' %></td>
              <td class="l"><%= wo.suite_number || '—' %></td>
              <td class="l"<%= wo.vendor_name ? '' : ' style="color:var(--text-faint)"' %>><%= wo.vendor_name || 'Unassigned' %></td>
              <td><span class="chip <%= wo.priority === 'emergency' || wo.priority === 'urgent' ? 'block' : wo.priority === 'low' ? 'ok' : 'pend' %>"><%= wo.priority %></span></td>
              <td><span class="chip <%= wo.status === 'completed' || wo.status === 'closed' ? 'ok' : wo.status === 'submitted' || wo.status === 'pending' ? 'pend' : 'block' %>"><%= wo.status %></span></td>
              <td class="num"><%= fmtDate(wo.created_at) %></td>
            </tr>
    <% } %>
          </tbody>
        </table>
      </div>
  <% } %>
<% } %>
    </section>
  </main>
</div>

<script>
document.getElementById('bldg-pick').addEventListener('change', function() {
  window.location.href = '/maintenance?building=' + this.value;
});
</script>
<%- include('partials/mobile-nav') %>
</body>
</html>
