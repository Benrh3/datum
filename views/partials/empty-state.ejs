<div style="border:1px solid var(--hairline);border-radius:var(--r,10px);padding:48px 28px;text-align:center">
  <div style="color:var(--text-dim);font-size:14px"><%= message %></div>
<% if (typeof sub !== 'undefined' && sub) { %>
  <div style="color:var(--text-faint);font-size:12.5px;margin-top:6px"><%= sub %></div>
<% } %>
</div>
