<%
function fmt(cents) {
  return '$' + (Math.abs(cents) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 });
}
function fmtVar(cents) {
  if (cents === 0) return '$0';
  return (cents > 0 ? '+' : '−') + fmt(cents);
}
function pctVar(budget, actual) {
  if (budget === 0) return 0;
  return (actual - budget) / Math.abs(budget) * 100;
}
function fmtPct(p) {
  if (Math.abs(p) < 0.05) return '0.0%';
  return (p > 0 ? '+' : '−') + Math.abs(p).toFixed(1) + '%';
}
function cls(v) { return v > 0 ? 'unf' : v < 0 ? 'fav' : 'flat'; }
function clr(v) { return v > 0 ? '--clay' : v < 0 ? '--mint' : '--text-faint'; }
function barW(b, a) {
  if (b === 0) return 0;
  return Math.min(48, Math.round(Math.abs((a - b) / b * 100) * 1.3));
}

const accrualMap = {};
accruals.forEach(a => { accrualMap[a.gl_account_id] = a; });
const quarter = Math.ceil(period / 3);
const varPct = pctVar(totalBudget, totalActual);
const isFavorable = totalVariance <= 0;

const sorted = [...detail].sort((a, b) =>
  (b.actual_cents - b.budget_cents) - (a.actual_cents - a.budget_cents));
const topUnfav = sorted.filter(r => r.actual_cents > r.budget_cents).slice(0, 2);
const topFav = sorted.filter(r => r.actual_cents < r.budget_cents).slice(0, 2);
%>
<!doctype html>
<html lang="en" data-mode="advanced">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Budget vs actual — <%= building.name %></title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --bg:        #0C0D0F;
    --surface:   #141619;
    --surface-2: #1A1D22;
    --hairline:  #24272C;
    --text:      #E7E9EC;
    --text-dim:  #969CA4;
    --text-faint:#5F646B;
    --mint:      #4FE3A1;
    --clay:      #DB9A63;
    --sans: "General Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, "SF Mono", monospace;
    --r: 10px;
    --r-sm: 6px;
    --pad: 28px;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body {
    background: var(--bg); color: var(--text);
    font-family: var(--sans); font-size: 14px; line-height: 1.5;
    -webkit-font-smoothing: antialiased; letter-spacing: 0.1px;
  }
  .num { font-family: var(--mono); font-variant-numeric: tabular-nums; }

  /* ---- shell --------------------------------------------------------- */
  .app { display: grid; grid-template-columns: 232px 1fr; min-height: 100vh; }

  .rail {
    border-right: 1px solid var(--hairline);
    padding: 22px 16px; display: flex; flex-direction: column; gap: 26px;
  }
  .brand { display: flex; align-items: center; gap: 10px; padding: 4px 8px; }
  .brand .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--mint); box-shadow: 0 0 0 0 rgba(79,227,161,.45);
    animation: pulse 2.6s ease-out infinite;
  }
  .brand b { font-weight: 600; letter-spacing: .2px; }
  .brand span { color: var(--text-faint); font-size: 12px; display:block; margin-top:1px; }

  nav { display: flex; flex-direction: column; gap: 2px; }
  nav a {
    display: flex; align-items: center; gap: 11px;
    padding: 9px 12px; border-radius: var(--r-sm);
    color: var(--text-dim); text-decoration: none; font-weight: 500;
    border-left: 2px solid transparent;
  }
  nav a:hover { background: var(--surface); color: var(--text); }
  nav a.active { color: var(--text); background: var(--surface); border-left-color: var(--mint); }
  nav a svg { width: 16px; height: 16px; stroke-width: 1.6; opacity: .9; }
  .nav-label { font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase;
               color: var(--text-faint); padding: 0 12px; margin-bottom: 4px; }

  /* ---- main ---------------------------------------------------------- */
  .main { min-width: 0; }
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 18px var(--pad);
    border-bottom: 1px solid var(--hairline);
  }
  .crumb { color: var(--text-faint); font-size: 12.5px; }
  .crumb b { color: var(--text-dim); font-weight: 500; }
  .topbar h1 { font-size: 19px; font-weight: 600; margin: 2px 0 0; letter-spacing: .2px; }
  .asof { display: flex; align-items: center; gap: 16px; }
  .live { display: flex; align-items: center; gap: 7px; color: var(--text-dim); font-size: 12.5px; }
  .live .d { width:7px;height:7px;border-radius:50%;background:var(--mint);
             box-shadow:0 0 0 0 rgba(79,227,161,.5); animation:pulse 2.6s ease-out infinite; }

  .toggle {
    display: inline-flex; align-items: center; gap: 9px;
    background: var(--surface); border: 1px solid var(--hairline);
    border-radius: 999px; padding: 6px 12px 6px 14px; cursor: pointer;
    color: var(--text-dim); font: inherit; font-size: 12.5px; font-weight: 500;
  }
  .toggle:hover { color: var(--text); }
  .toggle .sw { width: 30px; height: 17px; border-radius: 999px; background: var(--hairline);
                position: relative; transition: background .18s; }
  .toggle .sw::after { content:""; position:absolute; top:2px; left:2px; width:13px; height:13px;
                       border-radius:50%; background:var(--text-dim); transition: transform .18s, background .18s; }
  [data-mode="beginner"] .toggle .sw { background: var(--mint); }
  [data-mode="beginner"] .toggle .sw::after { transform: translateX(13px); background:#0C0D0F; }

  /* ---- hero ---------------------------------------------------------- */
  .hero { padding: 30px var(--pad) 22px; border-bottom: 1px solid var(--hairline); }
  .hero .lbl { color: var(--text-faint); font-size: 12px; letter-spacing: 1.4px; text-transform: uppercase; }
  .hero .fig { font-family: var(--mono); font-size: 46px; font-weight: 500; letter-spacing: -1px;
               margin: 8px 0 4px; color: var(--clay); }
  .hero .fig.fav { color: var(--mint); }
  .hero .pct { font-size: 17px; color: var(--text-dim); }
  .hero .read { max-width: 60ch; color: var(--text-dim); margin: 12px 0 0; }
  .hero .totals { display: flex; gap: 30px; margin-top: 18px; }
  .hero .totals div span { display:block; color: var(--text-faint); font-size: 12px; margin-bottom: 3px; }
  .hero .totals div b { font-family: var(--mono); font-weight: 500; font-size: 16px; }

  /* ---- the ledger ---------------------------------------------------- */
  .report { padding: 22px var(--pad) 40px; }
  .report-head { display: flex; align-items: baseline; justify-content: space-between;
                 margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
  .report-head h2 { font-size: 14px; font-weight: 600; margin: 0; letter-spacing: .2px; }
  .report-head .hint { color: var(--text-faint); font-size: 12px; }

  .controls { display: flex; gap: 8px; align-items: center; }
  .ctl {
    height: 31px; background: var(--surface); border: 1px solid var(--hairline);
    border-radius: var(--r-sm); color: var(--text-dim);
    padding: 0 12px; font-family: var(--sans); font-size: 12.5px; font-weight: 500;
    outline: none; transition: border-color .15s, color .15s;
  }
  .ctl:hover { color: var(--text); }
  .ctl:focus { border-color: var(--mint); color: var(--text); }
  .ctl::placeholder { color: var(--text-faint); font-weight: 500; }
  .ctl-search { width: 170px; }
  .ctl-num {
    width: 72px; font-family: var(--mono); font-variant-numeric: tabular-nums;
    border-radius: var(--r-sm) 0 0 var(--r-sm); border-right: none;
    -moz-appearance: textfield;
  }
  .ctl-num::-webkit-inner-spin-button,
  .ctl-num::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .ctl-sel {
    padding: 0 28px 0 10px; border-radius: 0 var(--r-sm) var(--r-sm) 0;
    -webkit-appearance: none; -moz-appearance: none; appearance: none; cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23969CA4' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 10px center;
  }
  .filter-group { display: flex; }

  .tbl-wrap { overflow-x: auto; border: 1px solid var(--hairline); border-radius: var(--r); background: var(--surface); }
  table { width: 100%; border-collapse: collapse; min-width: 640px; }
  thead th {
    text-align: right; font-weight: 500; color: var(--text-faint);
    font-size: 11px; letter-spacing: .8px; text-transform: uppercase;
    padding: 13px 16px; border-bottom: 1px solid var(--hairline); white-space: nowrap;
  }
  thead th.l { text-align: left; }
  tbody td { padding: 14px 16px; border-bottom: 1px solid var(--hairline); text-align: right; white-space: nowrap; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: var(--surface-2); }
  td.l { text-align: left; }
  .code { color: var(--text-faint); font-family: var(--mono); font-size: 12.5px; }
  .acct { color: var(--text); font-weight: 500; }
  .accr { display: block; color: var(--text-faint); font-size: 11.5px; margin-top: 2px; }
  .accr i { color: var(--mint); font-style: normal; }

  .chip { display: inline-flex; align-items: center; gap: 5px; font-family: var(--mono);
          font-size: 12.5px; padding: 3px 8px; border-radius: var(--r-sm); }
  .chip.fav { color: var(--mint); background: rgba(79,227,161,.10); }
  .chip.unf { color: var(--clay); background: rgba(219,154,99,.10); }
  .chip.flat{ color: var(--text-faint); background: var(--surface-2); }

  .bar { width: 96px; height: 6px; border-radius: 3px; background: var(--surface-2);
         position: relative; display: inline-block; vertical-align: middle; }
  .bar i { position: absolute; top: 0; height: 100%; border-radius: 3px; }
  .bar .mid { left: 50%; width: 1px; background: var(--hairline); top: -2px; height: 10px; }
  .bar i.fav { right: 50%; background: var(--mint); }
  .bar i.unf { left: 50%; background: var(--clay); }
  .col-bar { width: 1px; }

  tfoot td { padding: 15px 16px; border-top: 1px solid var(--hairline);
             font-weight: 600; text-align: right; }
  tfoot td.l { text-align: left; }

  /* ---- group rows ---------------------------------------------------- */
  .group-row { cursor: pointer; }
  .group-row td { background: rgba(26,29,34,.6); }
  .group-row .acct { font-weight: 600; }
  .chevron {
    display: inline-block; width: 16px; text-align: center;
    font-size: 11px; color: var(--text-dim); transition: transform .12s;
  }
  .detail-row td:nth-child(2) { padding-left: 32px; }

  /* progressive disclosure */
  [data-mode="beginner"] .tech { display: none; }

  .foot { color: var(--text-faint); font-size: 12px; margin-top: 16px; line-height: 1.6; }

  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(79,227,161,.45); }
    70%  { box-shadow: 0 0 0 7px rgba(79,227,161,0); }
    100% { box-shadow: 0 0 0 0 rgba(79,227,161,0); }
  }
  @media (prefers-reduced-motion: reduce) { * { animation: none !important; } }
  :focus-visible { outline: 2px solid var(--mint); outline-offset: 2px; border-radius: 4px; }

  @media (max-width: 860px) {
    .app { grid-template-columns: 1fr; }
    .rail { flex-direction: row; align-items: center; overflow-x: auto; gap: 14px;
            border-right: none; border-bottom: 1px solid var(--hairline); padding: 14px 16px; }
    .rail nav { flex-direction: row; }
    .nav-label { display: none; }
    nav a span.t { display: none; }
    .hero .fig { font-size: 38px; }
    .hero .totals { flex-wrap: wrap; gap: 18px 30px; }
    .report-head { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>
<div class="app">

  <!-- nav rail -->
  <aside class="rail">
    <div class="brand">
      <div class="dot" aria-hidden="true"></div>
      <div><b><%= building.name %></b><span><%= building.entity_name %></span></div>
    </div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h4l3 7 4-14 3 7h4"/></svg><span class="t">Leases</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3v18M5 8l7-5 7 5M5 8v8l7 5 7-5V8"/></svg><span class="t">Recoveries</span></a>
    </nav>
  </aside>

  <!-- main -->
  <main class="main">
    <div class="topbar">
      <div>
        <div class="crumb"><b>Accounting</b> &nbsp;/&nbsp; Operating budget</div>
        <h1>Budget vs actual</h1>
      </div>
      <div class="asof">
        <span class="live"><span class="d" aria-hidden="true"></span> As of <span id="asof"></span></span>
        <button class="toggle" id="mode" aria-pressed="false">
          <span class="sw" aria-hidden="true"></span> Plain view
        </button>
      </div>
    </div>

    <!-- hero -->
    <section class="hero">
      <div class="lbl">Net variance to budget &middot; Q<%= quarter %> <%= year %></div>
      <div class="fig<%= isFavorable ? ' fav' : '' %>"><%= fmtVar(totalVariance) %></div>
      <span class="pct"><%= Math.abs(varPct).toFixed(1) %>% <%= isFavorable ? 'under' : 'over' %> budget</span>
      <p class="read">Operating costs ran <strong style="color:var(--text)"><%= Math.abs(varPct).toFixed(1) %>% <%= isFavorable ? 'under' : 'over' %> plan</strong> this quarter<% if (topUnfav.length) { %>, driven by <%= topUnfav.map(r => r.account_name.toLowerCase()).join(' and ') %><% } %>.<% if (topFav.length) { %> Lower <%= topFav.map(r => r.account_name.toLowerCase()).join(' and ') %> spend offset part of the overrun.<% } %> Figures are accrual-adjusted through period close.</p>
      <div class="totals">
        <div><span>Budgeted</span><b><%= fmt(totalBudget) %></b></div>
        <div><span>Actual</span><b><%= fmt(totalActual) %></b></div>
        <div><span>Open accruals</span><b style="color:var(--mint)"><%= fmt(totalAccruals) %></b></div>
      </div>
    </section>

    <!-- the ledger -->
    <section class="report">
      <div class="report-head">
        <div>
          <h2>By account</h2>
          <span class="hint">Quarter to date &middot; favorable in mint, over budget in clay</span>
        </div>
        <div class="controls">
          <input type="text" id="search" class="ctl ctl-search" placeholder="Search accounts…">
          <div class="filter-group">
            <input type="number" id="filter-val" class="ctl ctl-num" value="" min="0" placeholder="0">
            <select id="filter-mode" class="ctl ctl-sel">
              <option value="$">$ min</option>
              <option value="%">% min</option>
            </select>
          </div>
        </div>
      </div>

      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th class="l tech">Code</th>
              <th class="l">Account</th>
              <th>Budget</th>
              <th>Actual</th>
              <th>Variance</th>
              <th>%</th>
              <th class="tech col-bar"></th>
            </tr>
          </thead>
          <tbody>
<% for (const g of grouped) {
     const gVar = g.variance_cents;
     const gPct = pctVar(g.budget_cents, g.actual_cents);
%>
            <tr class="group-row" data-group="<%= g.group_id %>">
              <td class="l code tech"><%= g.group_code %></td>
              <td class="l"><span class="acct"><span class="chevron">▸</span> <%= g.group_name %></span></td>
              <td class="num"><%= fmt(g.budget_cents) %></td>
              <td class="num"><%= fmt(g.actual_cents) %></td>
              <td><span class="chip <%= cls(gVar) %>"><%= fmtVar(gVar) %></span></td>
              <td class="num" style="color:var(<%= clr(gVar) %>)"><%= fmtPct(gPct) %></td>
              <td class="tech"><span class="bar"><i class="mid"></i><% if (gVar !== 0) { %><i class="<%= cls(gVar) %>" style="width:<%= barW(g.budget_cents, g.actual_cents) %>px"></i><% } %></span></td>
            </tr>
<%   const children = detail.filter(d => d.parent_id === g.group_id);
     for (const d of children) {
       const dVar = d.actual_cents - d.budget_cents;
       const dPct = pctVar(d.budget_cents, d.actual_cents);
       const acc = accrualMap[d.gl_account_id];
%>
            <tr class="detail-row" data-parent="<%= g.group_id %>"
                data-code="<%= d.account_code %>" data-name="<%= d.account_name %>"
                data-variance="<%= dVar %>" data-budget="<%= d.budget_cents %>"
                style="display:none">
              <td class="l code tech"><%= d.account_code %></td>
              <td class="l"><span class="acct"><%= d.account_name %></span><% if (acc) { %>
                  <span class="accr tech">incl. <i><%= fmt(acc.amount_cents) %></i> accrual &middot; <%= acc.note %></span><% } %></td>
              <td class="num"><%= fmt(d.budget_cents) %></td>
              <td class="num"><%= fmt(d.actual_cents) %></td>
              <td><span class="chip <%= cls(dVar) %>"><%= fmtVar(dVar) %></span></td>
              <td class="num" style="color:var(<%= clr(dVar) %>)"><%= fmtPct(dPct) %></td>
              <td class="tech"><span class="bar"><i class="mid"></i><% if (dVar !== 0) { %><i class="<%= cls(dVar) %>" style="width:<%= barW(d.budget_cents, d.actual_cents) %>px"></i><% } %></span></td>
            </tr>
<%   }
   } %>
          </tbody>
          <tfoot>
            <tr>
              <td class="l tech"></td>
              <td class="l">Total operating</td>
              <td class="num"><%= fmt(totalBudget) %></td>
              <td class="num"><%= fmt(totalActual) %></td>
              <td><span class="chip <%= cls(totalVariance) %>"><%= fmtVar(totalVariance) %></span></td>
              <td class="num" style="color:var(<%= clr(totalVariance) %>)"><%= fmtPct(varPct) %></td>
              <td class="tech"></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <p class="foot">
        Actuals include open accruals so the quarter reads true before every invoice lands;
        each accrual reverses next period when the real invoice is coded.
        Switch to <strong style="color:var(--text-dim)">Plain view</strong> to hide GL codes and accrual detail for a board-level read.
      </p>
    </section>
  </main>
</div>

<script>
(function () {
  // Plain / advanced toggle
  var btn = document.getElementById('mode');
  btn.addEventListener('click', function () {
    var on = document.documentElement.getAttribute('data-mode') === 'beginner';
    document.documentElement.setAttribute('data-mode', on ? 'advanced' : 'beginner');
    btn.setAttribute('aria-pressed', String(!on));
    btn.lastChild.textContent = on ? ' Plain view' : ' Full detail';
  });

  // As-of date
  try {
    document.getElementById('asof').textContent =
      new Date().toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' });
  } catch (e) {}

  // ---- drill-down, search, variance filter ----
  var expanded = {};
  var searchEl = document.getElementById('search');
  var filterValEl = document.getElementById('filter-val');
  var filterModeEl = document.getElementById('filter-mode');

  // Group row click
  document.querySelectorAll('.group-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var gid = this.dataset.group;
      expanded[gid] = !expanded[gid];
      update();
    });
  });

  searchEl.addEventListener('input', update);
  filterValEl.addEventListener('input', update);
  filterModeEl.addEventListener('change', update);

  function update() {
    var query = searchEl.value.toLowerCase().trim();
    var threshold = Number(filterValEl.value) || 0;
    var mode = filterModeEl.value;
    var isFiltering = !!(query || threshold > 0);

    var visibleParents = {};

    // Detail rows
    document.querySelectorAll('.detail-row').forEach(function (row) {
      var pid = row.dataset.parent;
      var code = (row.dataset.code || '').toLowerCase();
      var name = (row.dataset.name || '').toLowerCase();
      var v = Number(row.dataset.variance);
      var b = Number(row.dataset.budget);
      var show = true;

      if (query) {
        show = code.indexOf(query) !== -1 || name.indexOf(query) !== -1;
      }
      if (show && threshold > 0) {
        if (mode === '$') {
          show = Math.abs(v / 100) >= threshold;
        } else {
          show = b > 0 && Math.abs(v / b * 100) >= threshold;
        }
      }
      if (show && !isFiltering) {
        show = !!expanded[pid];
      }

      row.style.display = show ? '' : 'none';
      if (show) visibleParents[pid] = true;
    });

    // Group rows
    document.querySelectorAll('.group-row').forEach(function (row) {
      var gid = row.dataset.group;
      var chevron = row.querySelector('.chevron');

      if (isFiltering) {
        row.style.display = visibleParents[gid] ? '' : 'none';
        if (chevron) chevron.textContent = '▾';
      } else {
        row.style.display = '';
        if (chevron) chevron.textContent = expanded[gid] ? '▾' : '▸';
      }
    });
  }

  update();
})();
</script>
</body>
</html>
