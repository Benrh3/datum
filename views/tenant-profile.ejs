<%
function fmt(cents) {
  return '$' + (Math.abs(cents) / 100).toLocaleString('en-US', { maximumFractionDigits: 0 });
}
function fmtDate(iso) {
  if (!iso) return '—';
  var p = iso.split('T')[0].split('-');
  var m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return m[+p[1] - 1] + ' ' + Number(p[2]) + ', ' + p[0];
}
function fmtLease(type) {
  if (type === 'nnn') return 'NNN';
  if (type === 'modified_gross') return 'Mod. gross';
  return type.charAt(0).toUpperCase() + type.slice(1);
}

const totalAnnualRent = leases.reduce((s, l) => s + l.current_annual_rent_cents, 0);
const openArrears = arrears
  .filter(a => a.status !== 'paid')
  .reduce((s, a) => s + (a.amount_cents - a.paid_cents), 0);
%>
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tenant — <%= tenant.name %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #0C0D0F;
    --surface:   #141619;
    --surface-2: #1A1D22;
    --hairline:  #24272C;
    --text:      #E7E9EC;
    --text-dim:  #969CA4;
    --text-faint:#5F646B;
    --mint:      #4FE3A1;
    --clay:      #DB9A63;
    --sans: "General Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, "SF Mono", monospace;
    --r: 10px;
    --r-sm: 6px;
    --pad: 28px;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body {
    background: var(--bg); color: var(--text);
    font-family: var(--sans); font-size: 14px; line-height: 1.5;
    -webkit-font-smoothing: antialiased; letter-spacing: 0.1px;
  }
  .num { font-family: var(--mono); font-variant-numeric: tabular-nums; }

  /* ---- shell --------------------------------------------------------- */
  .app { display: grid; grid-template-columns: 232px 1fr; min-height: 100vh; }

  .rail {
    border-right: 1px solid var(--hairline);
    padding: 22px 16px; display: flex; flex-direction: column; gap: 26px;
  }
  .brand { display: flex; align-items: center; gap: 10px; padding: 4px 8px; }
  .brand .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--mint); box-shadow: 0 0 0 0 rgba(79,227,161,.45);
    animation: pulse 2.6s ease-out infinite;
  }

  nav { display: flex; flex-direction: column; gap: 2px; }
  nav a {
    display: flex; align-items: center; gap: 11px;
    padding: 9px 12px; border-radius: var(--r-sm);
    color: var(--text-dim); text-decoration: none; font-weight: 500;
    border-left: 2px solid transparent;
  }
  nav a:hover { background: var(--surface); color: var(--text); }
  nav a.active { color: var(--text); background: var(--surface); border-left-color: var(--mint); }
  nav a svg { width: 16px; height: 16px; stroke-width: 1.6; opacity: .9; }
  .nav-label { font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase;
               color: var(--text-faint); padding: 0 12px; margin-bottom: 4px; }

  .bldg-pick{width:100%;background:transparent;border:1px solid transparent;border-radius:var(--r-sm);
    color:var(--text);font-family:var(--sans);font-weight:600;font-size:14px;letter-spacing:.2px;
    padding:4px 22px 4px 0;appearance:none;cursor:pointer;outline:none;
    background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%235F646B' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat:no-repeat;background-position:right 2px center;}
  .bldg-pick:hover,.bldg-pick:focus{border-color:var(--hairline);}
  .bldg-pick option{background:var(--surface);color:var(--text);}

  /* ---- main ---------------------------------------------------------- */
  .main { min-width: 0; }
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 18px var(--pad);
    border-bottom: 1px solid var(--hairline);
  }
  .crumb { color: var(--text-faint); font-size: 12.5px; }
  .crumb b { color: var(--text-dim); font-weight: 500; }
  .topbar h1 { font-size: 19px; font-weight: 600; margin: 2px 0 0; letter-spacing: .2px; }

  /* ---- summary strip ------------------------------------------------- */
  .summary {
    display: flex; gap: 30px; padding: 24px var(--pad);
    border-bottom: 1px solid var(--hairline);
  }
  .summary div span { display: block; color: var(--text-faint); font-size: 12px; margin-bottom: 3px; }
  .summary div b { font-family: var(--mono); font-weight: 500; font-size: 16px; }

  /* ---- two-column layout --------------------------------------------- */
  .columns {
    display: grid; grid-template-columns: 1.5fr 1fr; gap: 0;
    min-height: 0;
  }
  .col-left {
    padding: 22px var(--pad) 40px;
    border-right: 1px solid var(--hairline);
  }
  .col-right {
    padding: 22px var(--pad) 40px;
  }

  /* ---- section blocks ------------------------------------------------ */
  .section { margin-bottom: 32px; }
  .section:last-child { margin-bottom: 0; }
  .section-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 14px;
  }
  .section-head h2 { font-size: 14px; font-weight: 600; margin: 0; letter-spacing: .2px; }
  .section-head .hint { color: var(--text-faint); font-size: 12px; }

  /* ---- tables -------------------------------------------------------- */
  .tbl-wrap { overflow-x: auto; border: 1px solid var(--hairline); border-radius: var(--r); background: var(--surface); }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    text-align: right; font-weight: 500; color: var(--text-faint);
    font-size: 11px; letter-spacing: .8px; text-transform: uppercase;
    padding: 13px 16px; border-bottom: 1px solid var(--hairline); white-space: nowrap;
  }
  thead th.l { text-align: left; }
  tbody td { padding: 14px 16px; border-bottom: 1px solid var(--hairline); text-align: right; white-space: nowrap; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: var(--surface-2); }
  td.l { text-align: left; }

  .lease-badge {
    display: inline-block; font-size: 11px; letter-spacing: .6px; text-transform: uppercase;
    color: var(--text-dim); background: var(--surface-2); padding: 2px 7px; border-radius: var(--r-sm);
  }

  /* ---- chips --------------------------------------------------------- */
  .chip {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11.5px; font-weight: 500; padding: 3px 8px;
    border-radius: var(--r-sm); letter-spacing: .2px;
  }
  .chip.ok    { color: var(--mint); background: rgba(79,227,161,.10); }
  .chip.block { color: var(--clay); background: rgba(219,154,99,.10); }
  .chip.pend  { color: var(--text-dim); background: var(--surface-2); }

  /* ---- card lists (contacts, documents, notices) --------------------- */
  .card-list { display: flex; flex-direction: column; gap: 0; }
  .card-item {
    padding: 14px 16px; border-bottom: 1px solid var(--hairline);
    border-left: 1px solid var(--hairline); border-right: 1px solid var(--hairline);
    background: var(--surface);
  }
  .card-item:first-child { border-top: 1px solid var(--hairline); border-radius: var(--r) var(--r) 0 0; }
  .card-item:last-child { border-radius: 0 0 var(--r) var(--r); border-bottom: 1px solid var(--hairline); }
  .card-item:only-child { border-radius: var(--r); }
  .card-item:hover { background: var(--surface-2); }
  .card-item .card-title { font-weight: 500; }
  .card-item .card-dim { color: var(--text-dim); font-size: 13px; }
  .card-item .card-faint { color: var(--text-faint); font-size: 12px; }
  .card-item .card-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .card-item .card-meta { display: flex; align-items: center; gap: 8px; margin-top: 4px; }

  .primary-badge {
    display: inline-block; font-size: 10px; letter-spacing: .6px; text-transform: uppercase;
    color: var(--mint); background: rgba(79,227,161,.10); padding: 1px 6px; border-radius: var(--r-sm);
    font-weight: 500;
  }

  .doc-type-badge {
    display: inline-block; font-size: 11px; letter-spacing: .6px; text-transform: uppercase;
    color: var(--text-dim); background: var(--surface-2); padding: 2px 7px; border-radius: var(--r-sm);
  }

  .truncate {
    max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    display: inline-block; vertical-align: bottom;
  }

  .empty { color: var(--text-faint); padding: 24px 16px; text-align: center; font-size: 13px; }

  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(79,227,161,.45); }
    70%  { box-shadow: 0 0 0 7px rgba(79,227,161,0); }
    100% { box-shadow: 0 0 0 0 rgba(79,227,161,0); }
  }
  @media (prefers-reduced-motion: reduce) { * { animation: none !important; } }
  :focus-visible { outline: 2px solid var(--mint); outline-offset: 2px; border-radius: 4px; }


</style>
</head>
<body>
<div class="app">

  <!-- nav rail -->
  <aside class="rail">
    <div class="brand">
      <div class="dot" aria-hidden="true"></div>
      <div>
        <select class="bldg-pick" id="bldg-pick">
<% for (const b of allBuildings) { %>
          <option value="<%= b.id %>"<%= b.id === buildingId ? ' selected' : '' %>><%= b.name %></option>
<% } %>
        </select>
      </div>
    </div>
    <nav aria-label="Sections">
      <div class="nav-label">Portfolio</div>
      <a href="/"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="t">Overview</span></a>
      <a href="/rent-roll?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h2m-2 4h2m4-4h2m-2 4h2"/></svg><span class="t">Rent roll</span></a>
      <div class="nav-label">Accounting</div>
      <a href="/budget-vs-actual?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18M8 14l3-3 3 3 5-6"/></svg><span class="t">Budget vs actual</span></a>
      <a href="/ap-review?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 5h16v14H4zM4 9h16M9 13h6"/></svg><span class="t">Accounts payable</span></a>
      <a href="/receivables?building=<%= buildingId %>"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v20M2 12h20M6 6l12 12M18 6L6 18"/></svg><span class="t">Receivables</span></a>
      <div class="nav-label">Reports</div>
      <a href="/reports/owner-statement"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="t">Owner statement</span></a>
      <a href="/reports/miscoding-review"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 9v4m0 4h.01M10.3 3.9L2 18a2 2 0 001.7 3h16.6a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg><span class="t">Miscoding review</span></a>
    </nav>
  </aside>

  <!-- main -->
  <main class="main">
    <div class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h18M3 6h18M3 18h18"/></svg></button>
      <div>
        <div class="crumb"><b>Portfolio</b> &nbsp;/&nbsp; Tenant profile</div>
        <h1><%= tenant.name %></h1>
      </div>
    </div>

    <!-- summary strip -->
    <section class="summary">
      <div><span>Leases</span><b><%= leases.length %></b></div>
      <div><span>Annual rent</span><b><%= fmt(totalAnnualRent) %></b></div>
      <div><span>Documents</span><b><%= documents.length %></b></div>
      <div><span>Open arrears</span><b style="color:<%= openArrears > 0 ? 'var(--clay)' : 'var(--text)' %>"><%= fmt(openArrears) %></b></div>
    </section>

    <!-- two-column layout -->
    <div class="columns profile-grid">

      <!-- LEFT column -->
      <div class="col-left">

        <!-- Leases -->
        <div class="section">
          <div class="section-head">
            <h2>Leases</h2>
            <span class="hint"><%= leases.length %> active</span>
          </div>
<% if (leases.length === 0) { %>
          <div class="empty">No leases on file.</div>
<% } else { %>
          <div class="tbl-wrap">
            <table>
              <thead>
                <tr>
                  <th class="l">Suite</th>
                  <th class="l">Building</th>
                  <th>Type</th>
                  <th>Term</th>
                  <th>Annual rent</th>
                </tr>
              </thead>
              <tbody>
<% for (const l of leases) { %>
                <tr>
                  <td class="l" style="font-family:var(--mono);font-size:12.5px;color:var(--text-faint)"><%= l.suite_number %></td>
                  <td class="l" style="font-weight:500"><%= l.building_name %></td>
                  <td><span class="lease-badge"><%= fmtLease(l.lease_type) %></span></td>
                  <td class="num" style="font-size:12.5px"><%= fmtDate(l.commencement_date) %> &rarr; <%= fmtDate(l.expiry_date) %></td>
                  <td class="num"><%= fmt(l.current_annual_rent_cents) %></td>
                </tr>
<% } %>
              </tbody>
            </table>
          </div>
<% } %>
        </div>

        <!-- Maintenance requests -->
        <div class="section">
          <div class="section-head">
            <h2>Maintenance requests</h2>
            <span class="hint"><%= requests.length %> total</span>
          </div>
<% if (requests.length === 0) { %>
          <div class="empty">No maintenance requests.</div>
<% } else { %>
          <div class="tbl-wrap">
            <table>
              <thead>
                <tr>
                  <th class="l">Date</th>
                  <th class="l">Suite</th>
                  <th class="l">Category</th>
                  <th class="l">Description</th>
                  <th>Priority</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
<% for (const r of requests) { %>
                <tr>
                  <td class="l num" style="font-size:12.5px"><%= fmtDate(r.submitted_at) %></td>
                  <td class="l" style="font-family:var(--mono);font-size:12.5px;color:var(--text-faint)"><%= r.suite_number %></td>
                  <td class="l" style="text-transform:capitalize"><%= r.category %></td>
                  <td class="l"><span class="truncate" style="max-width:180px"><%= r.description %></span></td>
                  <td><span class="chip <%= r.priority === 'high' || r.priority === 'urgent' ? 'block' : r.priority === 'low' ? 'ok' : 'pend' %>"><%= r.priority %></span></td>
                  <td><span class="chip <%= r.status === 'resolved' || r.status === 'closed' ? 'ok' : r.status === 'open' || r.status === 'new' ? 'block' : 'pend' %>"><%= r.status %></span></td>
                </tr>
<% } %>
              </tbody>
            </table>
          </div>
<% } %>
        </div>

        <!-- Arrears -->
<% if (arrears.length > 0) { %>
        <div class="section">
          <div class="section-head">
            <h2>Arrears</h2>
            <span class="hint"><%= arrears.filter(a => a.status !== 'paid').length %> outstanding</span>
          </div>
          <div class="tbl-wrap">
            <table>
              <thead>
                <tr>
                  <th class="l">Period</th>
                  <th class="l">Type</th>
                  <th>Charged</th>
                  <th>Paid</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
<% for (const a of arrears) {
     var mn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
%>
                <tr>
                  <td class="l"><%= mn[a.period_month - 1] %> <%= a.period_year %></td>
                  <td class="l" style="text-transform:uppercase;font-size:11px;letter-spacing:.5px;color:var(--text-faint)"><%= a.charge_type %></td>
                  <td class="num"><%= fmt(a.amount_cents) %></td>
                  <td class="num"><%= fmt(a.paid_cents) %></td>
                  <td><span class="chip <%= a.status === 'paid' ? 'ok' : a.status === 'partial' ? 'block' : 'pend' %>"><%= a.status %></span></td>
                </tr>
<% } %>
              </tbody>
            </table>
          </div>
        </div>
<% } %>

      </div>

      <!-- RIGHT column -->
      <div class="col-right">

        <!-- Contacts -->
        <div class="section">
          <div class="section-head">
            <h2>Contacts</h2>
            <span class="hint"><%= contacts.length %> listed</span>
          </div>
<% if (contacts.length === 0) { %>
          <div class="empty">No contacts on file.</div>
<% } else { %>
          <div class="card-list">
<% for (const c of contacts) { %>
            <div class="card-item">
              <div class="card-row">
                <span class="card-title"><%= c.name %></span>
<% if (c.is_primary) { %>
                <span class="primary-badge">Primary</span>
<% } %>
              </div>
              <div class="card-dim"><%= c.role %></div>
              <div class="card-meta">
<% if (c.email) { %>
                <span class="card-faint"><%= c.email %></span>
<% } %>
<% if (c.email && c.phone) { %>
                <span style="color:var(--hairline)">&middot;</span>
<% } %>
<% if (c.phone) { %>
                <span class="card-faint"><%= c.phone %></span>
<% } %>
              </div>
            </div>
<% } %>
          </div>
<% } %>
        </div>

        <!-- Documents -->
        <div class="section">
          <div class="section-head">
            <h2>Documents</h2>
            <span class="hint"><%= documents.length %> on file</span>
          </div>
<% if (documents.length === 0) { %>
          <div class="empty">No documents uploaded.</div>
<% } else { %>
          <div class="card-list">
<% for (const d of documents) { %>
            <div class="card-item">
              <div class="card-row">
                <span class="doc-type-badge"><%= d.doc_type %></span>
                <span class="chip <%= d.status === 'approved' ? 'ok' : d.status === 'expired' ? 'block' : 'pend' %>"><%= d.status %></span>
              </div>
              <div class="card-dim" style="margin-top:4px"><%= d.description %></div>
              <div class="card-meta">
<% if (d.expiry_date) { %>
                <span class="card-faint">Expires <%= fmtDate(d.expiry_date) %></span>
<% } %>
<% if (d.uploaded_at) { %>
                <span style="color:var(--hairline)">&middot;</span>
                <span class="card-faint">Uploaded <%= fmtDate(d.uploaded_at) %></span>
<% } %>
              </div>
            </div>
<% } %>
          </div>
<% } %>
        </div>

        <!-- Notices -->
        <div class="section">
          <div class="section-head">
            <h2>Notices</h2>
            <span class="hint"><%= notices.length %> sent</span>
          </div>
<% if (notices.length === 0) { %>
          <div class="empty">No notices sent.</div>
<% } else { %>
          <div class="card-list">
<% for (const n of notices) { %>
            <div class="card-item">
              <div class="card-title"><%= n.subject %></div>
              <div class="card-dim truncate" style="margin-top:2px"><%= n.body %></div>
              <div class="card-meta">
                <span class="card-faint"><%= fmtDate(n.sent_at) %></span>
<% if (n.sent_by_name) { %>
                <span style="color:var(--hairline)">&middot;</span>
                <span class="card-faint"><%= n.sent_by_name %></span>
<% } %>
              </div>
            </div>
<% } %>
          </div>
<% } %>
        </div>

      </div>
    </div>
  </main>
</div>

<script>
(function () {
  document.getElementById('bldg-pick').addEventListener('change', function () {
    window.location.href = '/budget-vs-actual?building=' + this.value;
  });
})();
</script>
<%- include('partials/mobile-nav') %>
</body>
</html>
